# ============================================
# Application
# ============================================
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hw_mgr
POSTGRES_PORT=5432

# Connection string (auto-generated in docker-compose, override here if needed)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hw_mgr

# ============================================
# Nuxt Public Runtime Config
# ============================================
NUXT_PUBLIC_APP_NAME=Hardware Manager
NUXT_PUBLIC_API_BASE=http://localhost:3000/api

# ============================================
# JWT Secrets
# ============================================
JWT_SECRET=your-access-token-secret
JWT_REFRESH_SECRET=your-refresh-token-secret
