// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  USER
}

enum DeviceStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
  LOST
}

enum DeviceCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  UPGRADE
  INSPECTION
}

enum CategoryType {
  DEVICE
  COMPONENT
  ACCESSORY
}

enum ComponentStatus {
  AVAILABLE
  INSTALLED
  DEFECTIVE
  DISPOSED
}

// ==================== MODELS ====================

model User {
  id            String           @id // auto generated USR- prefix from application
  email         String           @unique
  name          String?
  password      String           // bcrypt hashed password
  role          Role             @default(USER)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  refreshTokens      RefreshToken[]
  assignments        Assignment[]
  maintenances       MaintenanceLog[] @relation("PerformedBy")
  accessoryCheckouts AccessoryCheckout[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id          String       @id // auto generated CAT- prefix from application
  name        String       @unique
  description String?
  type        CategoryType @default(DEVICE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  devices     Device[]
  components  Component[]
  accessories Accessory[]
}

model Supplier {
  id           String   @id // auto generated SUP- prefix from application
  name         String
  contactEmail String?
  contactPhone String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  devices      Device[]
  components   Component[]
  accessories  Accessory[]
}

model Location {
  id          String   @id // auto generated LOC- prefix from application
  name        String   @unique
  address     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  devices     Device[]
  components  Component[]
  accessories Accessory[]
}

model Device {
  id             String          @id // auto generated DEV- prefix from application
  name           String
  serialNumber   String          @unique
  model          String?
  manufacturer   String?
  status         DeviceStatus    @default(AVAILABLE)
  condition      DeviceCondition @default(NEW)
  purchaseDate   DateTime?
  purchasePrice  Float?
  warrantyExpiry DateTime?
  notes          String?
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id])
  supplierId     String?
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  locationId     String?
  location       Location?       @relation(fields: [locationId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assignments    Assignment[]
  maintenances   MaintenanceLog[]
  components     Component[]
  componentInstallations ComponentInstallation[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([locationId])
  @@index([status])
}

model Assignment {
  id         String    @id @default(uuid())
  deviceId   String
  device     Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt      DateTime        @default(now())
  returnedAt      DateTime?
  conditionBefore DeviceCondition @default(GOOD)
  conditionAfter  DeviceCondition?
  notes           String?
  createdAt       DateTime  @default(now())
  documents       AssignmentDocument[]

  @@index([deviceId])
  @@index([userId])
}

model AssignmentDocument {
  id           String         @id @default(uuid())
  assignmentId String
  assignment   Assignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  templateId   String?
  template     PrintTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  name         String
  fileUrl      String         // URL or path inside the server to access the generated PDF
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([assignmentId])
  @@index([templateId])
}

model MaintenanceLog {
  id                  String          @id @default(uuid())
  deviceId            String
  device              Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  type                MaintenanceType
  description         String
  cost                Float?
  performedAt         DateTime        @default(now())
  nextMaintenanceDate DateTime?
  performedById       String?
  performedBy         User?           @relation("PerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  createdAt           DateTime        @default(now())

  @@index([deviceId])
  @@index([performedById])
}

model PrintTemplate {
  id          String   @id @default(uuid()) // auto generated PRT- prefix could be used
  name        String   @unique
  description String?
  content     String   @db.Text
  type        String   // 'HANDOVER' | 'RETURN'
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  documents   AssignmentDocument[]
}

// ==================== COMPONENT & ACCESSORY ====================

model Component {
  id             String          @id // auto generated CMP- prefix from application
  name           String
  serialNumber   String?
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id])
  manufacturer   String?
  status         ComponentStatus @default(AVAILABLE)
  purchaseDate   DateTime?
  purchasePrice  Float?
  warrantyExpiry DateTime?
  notes          String?
  supplierId     String?
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  locationId     String?
  location       Location?       @relation(fields: [locationId], references: [id])
  deviceId       String?
  device         Device?         @relation(fields: [deviceId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  installations  ComponentInstallation[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([locationId])
  @@index([deviceId])
  @@index([status])
}

model ComponentInstallation {
  id           String    @id @default(uuid())
  componentId  String
  component    Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  deviceId     String
  device       Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  installedAt  DateTime  @default(now())
  removedAt    DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([componentId])
  @@index([deviceId])
}

model Accessory {
  id            String    @id // auto generated ACC- prefix from application
  name          String
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])
  manufacturer  String?
  totalQuantity Int       @default(0)
  minQuantity   Int       @default(0)
  unitPrice     Float?
  notes         String?
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  checkouts     AccessoryCheckout[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([locationId])
}

model AccessoryCheckout {
  id           String    @id @default(uuid())
  accessoryId  String
  accessory    Accessory @relation(fields: [accessoryId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quantity     Int       @default(1)
  checkedOutAt DateTime  @default(now())
  returnedAt   DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([accessoryId])
  @@index([userId])
}
